#include "itxecommerce-shared.xcconfig"

// Local variable
ENVIRONMENT = PROD

INFOPLIST_KEY_CFBundleDisplayName = eCatalog
INFOPLIST_FILE = $(PRODUCT_NAME)/App/Supporting Files/Info-$(ENVIRONMENT).plist
ASSETCATALOG_COMPILER_APPICON_NAME = AppIcon-$(ENVIRONMENT)

OTHER_SWIFT_FLAGS = $(inherited) -DCONF_$(ENVIRONMENT)
